def find_image_with_retry(
    matcher: ScreenImageMatcher,
) -> tuple[float, tuple[int, int] | None]:
    """
    Finds the image only inside the given screen region.
    """
    #print(f"Searching for image: {matcher.image_path}")
    left, top, width, height = region
    template_h, template_w = matcher.template.shape[:2]

    with mss.mss() as sct:
        for _ in range(matcher.max_retries):
            screenshot = sct.grab({
                "left": left,
                "top": top,
                "width": width,
                "height": height,
            })

            frame = cv2.cvtColor(
                np.array(screenshot),
                cv2.COLOR_BGRA2BGR
            )

            gray_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

            result = cv2.matchTemplate(
                gray_frame,
                matcher.template,
                cv2.TM_CCOEFF_NORMED
            )

            _, max_val, _, max_loc = cv2.minMaxLoc(result)

            if max_val >= matcher.confidence_threshold:
                match_x = max_loc[0] + template_w // 2
                match_y = max_loc[1] + template_h // 2

                # Convert back to absolute screen coords
                screen_x = left + match_x
                screen_y = top + match_y

                return float(max_val), (screen_x, screen_y)

            time.sleep(matcher.interval)

    return 0.0, None

def right_half_region(region: tuple[int, int, int, int]) -> tuple[int, int, int, int]:
    """
    Returns the right half of a window region.
    """
    left, top, width, height = region
    half_width = width // 2

    return (
        left + half_width,
        top + 150,              
        half_width,       
        height - 150,           
    )

class WindowFocuser:
    def __init__(self, title_substring: str):
        self.title_substring = title_substring
        all_windows = pywinctl.getAllWindows()
        self.windows = [
            w for w in all_windows
            if w.title and title_substring in w.title
        ]

        if not self.windows:
            raise RuntimeError(
                f"No windows found with title containing: {title_substring}"
            )

    def focus(self, window):
        if window.isMinimized:
            window.restore()

        window.show()
        window.raiseWindow()
        window.activate(wait=True)

    def get_bbox(self, window):
        return (
            window.left,
            window.top,
            window.width,
            window.height,
        )

