class ScreenImageMatcher:
    def __init__(
        self,
        image_path: str,
        max_retries: int = 10,
        interval: float = 0.1,
        confidence_threshold: float = 0.8,
    ):
        """
        Args:
            image_path: Path to the template image
            max_retries: Maximum number of screen checks
            interval: Delay between retries (seconds)
            confidence_threshold: Minimum confidence to consider a match
        """
        self.image_path = TEMPLATES_DIR / image_path
        self.max_retries = max_retries
        self.interval = interval
        self.confidence_threshold = confidence_threshold

        if not self.image_path.exists():
            raise FileNotFoundError(f"Template not found: {self.image_path}")

        # Load template once (grayscale)
        self.template = cv2.cvtColor(
            cv2.imread(str(self.image_path)),
            cv2.COLOR_BGR2GRAY
        )

        self.template_h, self.template_w = self.template.shape[:2]

def get_image_bbox(
    image_name: str,
    max_retries: int = 10,
    interval: float = 0.1,
    confidence_threshold: float = 0.9,
) -> tuple[int, int, int, int] | None:
    """
    Finds an image on screen and returns its bounding box as
    (x1, y1, x2, y2) in absolute screen coordinates.
    """

    matcher = ScreenImageMatcher(
        image_path=image_name,
        max_retries=max_retries,
        interval=interval,
        confidence_threshold=confidence_threshold,
    )

    left, top, width, height = region
    template_h, template_w = matcher.template.shape[:2]

    with mss.mss() as sct:
        for _ in range(matcher.max_retries):
            screenshot = sct.grab({
                "left": left,
                "top": top,
                "width": width,
                "height": height,
            })

            frame = cv2.cvtColor(
                np.array(screenshot), cv2.COLOR_BGRA2BGR
            )
            gray_frame = cv2.cvtColor(frame, cv2.COLOR_BGR2GRAY)

            result = cv2.matchTemplate(
                gray_frame,
                matcher.template,
                cv2.TM_CCOEFF_NORMED,
            )

            _, max_val, _, max_loc = cv2.minMaxLoc(result)

            if max_val >= matcher.confidence_threshold:
                x1 = left + max_loc[0]
                y1 = top + max_loc[1]
                x2 = x1 + template_w
                y2 = y1 + template_h

                return (x1, y1, x2, y2)

            time.sleep(matcher.interval)

    return None

def format_timedelta_hms(td):
    # Get total seconds from the timedelta object
    total_seconds = td.total_seconds()

    # Check for NaN value
    if math.isnan(total_seconds):
        return "00:00:00.000"  # Return a default string in case of NaN

    # Proceed with normal timedelta conversion
    hours, remainder = divmod(total_seconds, 3600)
    minutes, seconds = divmod(remainder, 60)
    
    # Return formatted time string
    return f"{int(hours):02d}:{int(minutes):02d}:{seconds:06.3f}"

