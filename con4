def find_and_click(imageName:str, max_retries:int = 20, interval:float = 0.3, click_attempts:int = 3)->bool:
    for attempt in range(click_attempts):
        matcher = ScreenImageMatcher(
            image_path=imageName,
            max_retries=max_retries,
            interval=interval
        )

        confidence, location = find_image_with_retry(matcher)
        if location is None:
            if attempt == 0:
                print(f"Image {imageName} not found on screen")
                return False
            else:
                # Image gone after a previous click — click worked
                return True

        x, y = location
        pydirectinput.moveTo(x, y)
        pydirectinput.click()
        time.sleep(0.3)

    return True
    
def click_bbox(
    x1: int,
    y1: int,
    x2: int,
    y2: int,
    *,
    offset_x: int = 0,
    offset_y: int = 0,
    center: bool = True,
    pause: float = 0.01,
):
    """
    Click inside a bounding box in absolute screen coordinates.

    Args:
        x1, y1, x2, y2: Bounding box (absolute screen coords)
        offset_x, offset_y: Pixel offset from the chosen click point
        center: If True, click center of bbox, else click top-left (x1,y1)
        pause: pydirectinput pause before clicking
    """

    if center:
        click_x = x1 + (x2 - x1) // 2
        click_y = y1 + (y2 - y1) // 2
    else:
        click_x = x1
        click_y = y1

    click_x += offset_x
    click_y += offset_y

    pydirectinput.PAUSE = pause
    pydirectinput.moveTo(click_x, click_y)
    pydirectinput.click()

def click_window_top_right(
    window_bbox: tuple[int, int, int, int],
    offset_x: int,
    offset_y: int,
):
    """
    Clicks a point offset from the top-right corner of a window.

    offset_x: pixels LEFT from top-right (positive value)
    offset_y: pixels DOWN from top-right
    """

    win_left, win_top, win_width, _ = window_bbox

    screen_x = win_left + win_width - offset_x
    screen_y = win_top + offset_y

    pydirectinput.moveTo(screen_x, screen_y)
    pydirectinput.click()

def save_bbox_screenshot(
    x1: int,
    y1: int,
    x2: int,
    y2: int,
    filename: str,
    output_dir: str,
):
    """
    Saves the screen area defined by (x1, y1, x2, y2)
    into <output_dir>/<filename>
    """

    width = x2 - x1
    height = y2 - y1

    if width <= 0 or height <= 0:
        raise ValueError("Invalid bounding box dimensions")

    output_path = Path(output_dir)
    output_path.mkdir(parents=True, exist_ok=True)

    full_path = output_path / filename

    with mss.mss() as sct:
        screenshot = sct.grab({
            "left": x1,
            "top": y1,
            "width": width,
            "height": height,
        })

        img = cv2.cvtColor(
            np.array(screenshot), cv2.COLOR_BGRA2BGR
        )

        cv2.imwrite(str(full_path), img)

    print(f"Saved screenshot: {full_path}")

def screenshot_current_window(
    window: pywinctl.Window,
    filename: str,
    output_dir: str,
):
    """
    Saves a screenshot of the entire window.
    """

    x1 = window.left
    y1 = window.top
    x2 = window.left + window.width
    y2 = window.top + window.height

    save_bbox_screenshot(
        x1=x1,
        y1=y1,
        x2=x2,
        y2=y2,
        filename=filename,
        output_dir=output_dir,
    )

def is_window_closer_to_right(window: pywinctl.Window) -> bool:
    """
    Returns True if the window is closer to the RIGHT half of its monitor,
    False if closer to the LEFT half.
    """
    # Window center
    win_center_x = window.left + window.width // 2
    win_center_y = window.top + window.height // 2

    with mss.mss() as sct:
        for mon in sct.monitors[1:]:  # skip virtual monitor 0
            mon_left = mon["left"]
            mon_top = mon["top"]
            mon_right = mon_left + mon["width"]
            mon_bottom = mon_top + mon["height"]

            if mon_left <= win_center_x < mon_right and mon_top <= win_center_y < mon_bottom:
                monitor_mid_x = mon_left + mon["width"] // 2
                return win_center_x >= monitor_mid_x

    raise RuntimeError("Window center not found on any monitor")

