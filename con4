def get_drive_service():
    creds = None

    if os.path.exists(TOKEN_FILE):
        with open(TOKEN_FILE, "rb") as token:
            creds = pickle.load(token)

    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            flow = InstalledAppFlow.from_client_secrets_file(
                OAUTH_FILE,
                SCOPES,
            )
            creds = flow.run_local_server(port=0)

        with open(TOKEN_FILE, "wb") as token:
            pickle.dump(creds, token)

    return build("drive", "v3", credentials=creds, static_discovery=False)

def find_drive_item(service, name: str, parent_id: str, mime_type: str | None = None):
    """
    Returns file/folder ID if it exists, otherwise None
    """
    q = [
        f"name='{name}'",
        f"'{parent_id}' in parents",
        "trashed=false",
    ]

    if mime_type:
        q.append(f"mimeType='{mime_type}'")

    query = " and ".join(q)

    results = service.files().list(
        q=query,
        spaces="drive",
        fields="files(id, name)",
        supportsAllDrives=True,
        includeItemsFromAllDrives=True,
    ).execute()

    files = results.get("files", [])
    return files[0]["id"] if files else None

def get_or_create_drive_folder(service, folder_name: str, parent_id: str) -> str:
    folder_id = find_drive_item(
        service,
        name=folder_name,
        parent_id=parent_id,
        mime_type="application/vnd.google-apps.folder",
    )

    if folder_id:
        print(f"Folder exists: {folder_name}")
        return folder_id

    print(f"Creating folder: {folder_name}")

    folder_metadata = {
        "name": folder_name,
        "mimeType": "application/vnd.google-apps.folder",
        "parents": [parent_id],
    }

    folder = service.files().create(
        body=folder_metadata,
        fields="id",
        supportsAllDrives=True,
    ).execute()

    return folder["id"]

def upload_file(service, file_path: Path, parent_id: str):
    print(f"Uploading (override if exists): {file_path.name}")

    mime_type, _ = mimetypes.guess_type(file_path)

    media = MediaFileUpload(
        str(file_path),
        mimetype=mime_type,
        resumable=True,
    )

    # Check if file already exists in this folder
    existing_file_id = find_drive_item(
        service,
        name=file_path.name,
        parent_id=parent_id,
    )

    if existing_file_id:
        # Update existing file
        service.files().update(
            fileId=existing_file_id,
            media_body=media,
            supportsAllDrives=True,
        ).execute()

        print(f"Overwritten: {file_path.name}")
        return existing_file_id

    # Create new file if not found
    file_metadata = {
        "name": file_path.name,
        "parents": [parent_id],
    }

    uploaded = service.files().create(
        body=file_metadata,
        media_body=media,
        fields="id",
        supportsAllDrives=True,
    ).execute()

    print(f"Uploaded new: {file_path.name}")
    return uploaded["id"]

def upload_account_files(
    service,
    local_dir: str,
    account_name: str,
    today: str,
):
    """
    Uploads all files containing account_name using folder rules.
    """

    # Parent folders (must already exist)
    TRADE_REPORTS_ROOT = "Trade reports"
    SCREENSHOT_ROOT = "Screenshot"

    # Get root folder IDs
    trade_reports_root_id = find_drive_item(
        service, TRADE_REPORTS_ROOT, DRIVE_PARENT_FOLDER_ID
    )
    screenshot_root_id = find_drive_item(
        service, SCREENSHOT_ROOT, DRIVE_PARENT_FOLDER_ID
    )

    if not trade_reports_root_id:
        raise RuntimeError("Trade reports folder not found on Drive")

    if not screenshot_root_id:
        raise RuntimeError("Screenshot folder not found on Drive")

    # Create date folders
    trade_date_id = get_or_create_drive_folder(
        service, today, trade_reports_root_id
    )
    screenshot_date_id = get_or_create_drive_folder(
        service, today, screenshot_root_id
    )

    # Account folder under Trade reports / today
    trade_account_id = get_or_create_drive_folder(
        service, account_name, trade_date_id
    )

    for filename in os.listdir(local_dir):
        if account_name not in filename:
            continue

        file_path = Path(local_dir) / filename
        if not file_path.is_file():
            continue

        lower = filename.lower()

        if any(k.lower() in lower for k in ["orders", "trades", "tickets"]):
            upload_file(
                service,
                file_path,
                trade_account_id,
            )

        elif "report" in lower:
            upload_file(
                service,
                file_path,
                screenshot_date_id,
            )

