from pathlib import Path
import json

# --- New functions for CSV upload from dated folders --- #

def load_config(config_file: str):
    """
    Loads JSON config from file.
    """
    with open(config_file, "r") as f:
        return json.load(f)

def get_target_date_folder(root_path: str, target_date: int):
    """
    Recursively finds all dated folders (YYYYMMDD) in subfolders of root_path
    that match the target_date.
    Returns a list of Path objects.
    """
    root = Path(root_path)
    target_str = str(target_date)
    matched_folders = []

    for subfolder in root.iterdir():
        if not subfolder.is_dir():
            continue
        for date_folder in subfolder.iterdir():
            if date_folder.is_dir() and date_folder.name == target_str:
                matched_folders.append(date_folder)

    return matched_folders

